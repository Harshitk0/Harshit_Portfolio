<main class="main">

    <!-- About Section -->
    <!-- About Section -->
    <section id="about" class="about section">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <h2>About</h2>
            <p>
                Passionate .NET Web Developer with hands-on experience in building responsive,
                scalable, and user-friendly web applications using ASP.NET Core MVC, React,
                SQL Server, and modern web technologies.
            </p>
        </div><!-- End Section Title -->

        <div class="container" data-aos="fade-up" data-aos-delay="100">

            <!-- Intro + Photo -->
            <div class="row align-items-center justify-content-between gy-5 mb-5">

                <div class="col-lg-7" data-aos="fade-right" data-aos-delay="150">
                    <div class="intro-content">

                        <span class="eyebrow">Hello There</span>

                        <h2 class="headline">
                            Hi, I'm Harshit — a passionate .NET Web Developer creating modern and responsive web applications.
                        </h2>

                        <p class="lead">
                            I specialize in ASP.NET Core MVC, C#, React, SQL Server, HTML, CSS,
                            Bootstrap, and JavaScript to build fast, scalable, and user-friendly
                            applications.
                        </p>

                        <p>
                            During my internship and personal projects, I developed E-Commerce,
                            Insurance Management, Job Portal, and React applications. I enjoy
                            solving real-world problems through clean code, database design,
                            RESTful APIs, and responsive user interfaces.
                        </p>

                        <div class="cta-group">
                            <a asp-controller="Home" asp-action="Portfolio" class="btn-ghost">
                                View My Work <i class="bi bi-arrow-up-right"></i>
                            </a>
                            

                            <a href="/assets/File/Harshit.pdf" download="Harshit_Resume.pdf" class="link-underline" >
                                Download Resume <i class="bi bi-download"></i>
                            </a>
                        </div>

                    </div>
                </div>

                <div class="col-lg-5" data-aos="zoom-in" data-aos-delay="250">
                    <figure class="profile-figure text-center text-lg-end">
                        <img src="~/assets/img/profile/Image3.png"
                             alt="Harshit Kumar"
                             class="img-fluid profile-photo">
                    </figure>
                </div>

            </div>
            <!-- End Intro + Photo -->
            <!-- Skills Grid -->
            <div class="mb-5">
                <div class="row g-4">

                    <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="120">
                        <div class="skill-item">
                            <i class="bi bi-code-slash"></i>
                            <h3>ASP.NET Core MVC</h3>
                            <p>Building scalable web applications.</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="180">
                        <div class="skill-item">
                            <i class="bi bi-window"></i>
                            <h3>React.js</h3>
                            <p>Developing modern interactive interfaces.</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="240">
                        <div class="skill-item">
                            <i class="bi bi-database"></i>
                            <h3>SQL Server</h3>
                            <p>Database design and CRUD operations.</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                        <div class="skill-item">
                            <i class="bi bi-git"></i>
                            <h3>Git & GitHub</h3>
                            <p>Version control and collaboration.</p>
                        </div>
                    </div>

                </div>
            </div>
            <!-- End Skills Grid -->
            <!-- Journey Timeline -->
            <div class="mb-5">
                <div class="row g-4">

                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="120">
                        <article class="timeline-item">
                            <span class="dot"></span>
                            <time>2023</time>
                            <h4>BCA Journey</h4>
                            <p>Started Bachelor of Computer Applications at GLA University.</p>
                        </article>
                    </div>

                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="180">
                        <article class="timeline-item">
                            <span class="dot"></span>
                            <time>2024</time>
                            <h4>Frontend Development</h4>
                            <p>Built responsive websites using HTML, CSS, Bootstrap and JavaScript.</p>
                        </article>
                    </div>

                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="240">
                        <article class="timeline-item">
                            <span class="dot"></span>
                            <time>2025</time>
                            <h4>Web Developer Intern</h4>
                            <p>Worked on E-Commerce, Insurance Management and Legal projects using ASP.NET Core MVC.</p>
                        </article>
                    </div>

                    <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                        <article class="timeline-item">
                            <span class="dot"></span>
                            <time>2026</time>
                            <h4>.NET Developer</h4>
                            <p>Focused on creating scalable full-stack web applications with modern technologies.</p>
                        </article>
                    </div>

                </div>
            </div>
            <!-- End Journey Timeline -->
            <!-- Quote -->
            <blockquote class="personal-quote text-center mb-5"
                        data-aos="fade-down"
                        data-aos-delay="200">
                <p>
                    "Turning ideas into responsive, scalable, and user-friendly web applications."
                </p>
            </blockquote>
            <!-- End Quote -->
            <!-- Fun Facts -->
            <div class="row g-3 justify-content-center">

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="120">
                    <div class="fact-pill">
                        <i class="bi bi-code-slash"></i>
                        <span>ASP.NET Core</span>
                    </div>
                </div>

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="160">
                    <div class="fact-pill">
                        <i class="bi bi-filetype-cs"></i>
                        <span>C#</span>
                    </div>
                </div>

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="200">
                    <div class="fact-pill">
                        <i class="bi bi-database"></i>
                        <span>SQL Server</span>
                    </div>
                </div>

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="240">
                    <div class="fact-pill">
                        <i class="bi bi-window"></i>
                        <span>React.js</span>
                    </div>
                </div>

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="280">
                    <div class="fact-pill">
                        <i class="bi bi-bar-chart"></i>
                        <span>Chart.js</span>
                    </div>
                </div>

                <div class="col-6 col-md-3 col-lg-2" data-aos="zoom-in" data-aos-delay="320">
                    <div class="fact-pill">
                        <i class="bi bi-github"></i>
                        <span>GitHub</span>
                    </div>
                </div>

            </div>
            <!-- End Fun Facts -->

        </div>

    </section>
