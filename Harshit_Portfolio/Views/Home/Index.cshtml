@{
    ViewData["Title"] = "Home Page";
}



    
    <main class="main">

        <!-- Hero Section -->
        <section id="hero" class="hero section">

            <div class="container" data-aos="fade-up" data-aos-delay="100">

                <div class="row gy-4 align-items-center">
                    <div class="col-lg-6 order-2 order-lg-1">
                    <div class="hero-content">
                        <h1 data-aos="fade-up" data-aos-delay="200">
                            Hello, I'm <span class="highlight">Harshit</span>
                        </h1>

                        <h2 data-aos="fade-up" data-aos-delay="300">
                            Creative <span class="typed" data-typed-items=".NET Developer, ASP.NET Core Developer"></span>
                        </h2>

                        <p data-aos="fade-up" data-aos-delay="400">
                            Aspiring .NET Web Developer passionate about building responsive web applications and continuously learning modern technologies to create impactful digital solutions.
                        </p>

                        <div class="hero-actions" data-aos="fade-up" data-aos-delay="500">
                            <a asp-controller="Home" asp-action="Portfolio" class="btn btn-primary">View My Projects</a>
                            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline">Hire Me</a>
                        </div>

                        <div class="social-links" data-aos="fade-up" data-aos-delay="600">

                            <!-- GitHub -->
                            <a href="https://github.com/Harshit-02" target="_blank" rel="noopener noreferrer" title="GitHub">
                                <i class="bi bi-github"></i>
                            </a>

                            <!-- LinkedIn -->
                            <a href="https://www.linkedin.com/in/harshit-kumar-b3a5512b4" target="_blank" rel="noopener noreferrer" title="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>

                            <!-- Email -->
                            <a href="mailto:harshitdelhisix@gmail.com" target="_blank" rel="noopener noreferrer"  title="Email">
                                <i class="bi bi-envelope-fill"></i>
                            </a>

                        </div>
                    </div>
                    </div>
                    <div class="col-lg-6 order-1 order-lg-2">
                        <div class="hero-image" data-aos="zoom-in" data-aos-delay="300">
                            <div class="image-wrapper">
                                <img src="~/assets/img/profile/Image4.png" alt="Sarah Mitchell" class="img-fluid">
                                <div class="floating-elements">
                                    <div class="floating-card design" data-aos="fade-left" data-aos-delay="700">
                                        <i class="bi bi-palette"></i>
                                        <span>Design</span>
                                    </div>
                                    <div class="floating-card code" data-aos="fade-right" data-aos-delay="800">
                                        <i class="bi bi-code-slash"></i>
                                        <span>Code</span>
                                    </div>
                                    <div class="floating-card creativity" data-aos="fade-up" data-aos-delay="900">
                                        <i class="bi bi-lightbulb"></i>
                                        <span>Ideas</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </section><!-- /Hero Section -->

    </main>
    
   

